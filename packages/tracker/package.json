{
  "name": "@symphony/tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./stdio-tracker-server": {
      "types": "./dist/tools/stdio-tracker-server.d.ts",
      "import": "./dist/tools/stdio-tracker-server.js",
      "default": "./dist/tools/stdio-tracker-server.js"
    }
  },
