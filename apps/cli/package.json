{
  "name": "@andrejvysny/symphony",
  "version": "0.1.0",
  "description": "Agent-agnostic coding-agent orchestrator — delegate tickets to local coding agents (Claude Code, codex, opencode) in isolated git worktrees, driven by a local file task store.",
  "keywords": [
    "claude",
    "claude-code",
    "coding-agent",
    "orchestrator",
    "ai",
    "automation",
    "git-worktree",
    "cli",
    "symphony"
  ],
  "license": "Apache-2.0",
  "author": "Andrej Vyšný <claudera@brch.sk>",
  "homepage": "https://github.com/andrejvysny/symphony-ts#readme",
  "bugs": "https://github.com/andrejvysny/symphony-ts/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrejvysny/symphony-ts.git",
    "directory": "apps/cli"
  },
  "type": "module",
  "bin": {
    "symphony": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.154",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "execa": "^9.6.1",
    "fastify": "^5.8.5",
    "liquidjs": "^10.27.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "simple-git": "^3.36.0",
    "undici": "^8.3.0",
    "yaml": "^2.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@symphony/agent-backends": "workspace:*",
    "@symphony/core": "workspace:*",
    "@symphony/dashboard": "workspace:*",
    "@symphony/shared": "workspace:*",
    "@symphony/tracker": "workspace:*"
  }
}
