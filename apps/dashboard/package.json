{
  "name": "@symphony/dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "pnpm clean && tsup && vite build -c client/vite.config.ts",
    "build:client": "vite build -c client/vite.config.ts",
    "dev": "tsup --watch",
    "dev:client": "vite -c client/vite.config.ts",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@symphony/core": "workspace:*",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "preact": "^10.29.2",
    "vite": "^8.0.14"
  }
}
