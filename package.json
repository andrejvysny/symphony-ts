{
  "name": "symphony-ts",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-agnostic coding-agent orchestrator (Symphony reimplementation in TypeScript)",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm build && concurrently -k -n libs,api,web -c blue,green,magenta \"pnpm dev:libs\" \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:libs": "pnpm -r --parallel --if-present run dev",
    "dev:api": "node --watch-path=./packages/shared/dist --watch-path=./packages/tracker/dist --watch-path=./packages/agent-backends/dist --watch-path=./packages/core/dist --watch-path=./apps/dashboard/dist apps/cli/dist/main.js ./WORKFLOW.md --port 4500",
    "dev:web": "pnpm --filter @symphony/dashboard run dev:client",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "release:pack": "pnpm --filter @andrejvysny/symphony exec clean-publish --package-manager npm --files \"dist/**/*.map\"",
    "release:publish": "pnpm build && pnpm release:pack"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "clean-publish": "^7.1.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.7"
  }
}
