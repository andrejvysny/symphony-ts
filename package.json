{
  "name": "symphony-ts",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-agnostic coding-agent orchestrator (Symphony reimplementation in TypeScript)",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "plane:up": "docker compose --env-file infra/plane/plane.env -f infra/plane/docker-compose.yml up -d",
    "plane:down": "docker compose --env-file infra/plane/plane.env -f infra/plane/docker-compose.yml down",
    "plane:ps": "docker compose --env-file infra/plane/plane.env -f infra/plane/docker-compose.yml ps",
    "plane:logs": "docker compose --env-file infra/plane/plane.env -f infra/plane/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.7"
  }
}
